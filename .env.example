# ─── HopeAid Backend — Environment Variables Template ────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=HopeAid
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ────────────────────────────────────────────────────────────────
# Sync SQLAlchemy driver
DATABASE_URL=postgresql+psycopg2://hopeaid:hopeaid@localhost:5432/hopeaid
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (also accepts JSON array string)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ─── Storage (S3-compatible) ─────────────────────────────────────────────────
# Leave S3_ENDPOINT_URL empty for AWS S3
# For Supabase: https://<project>.supabase.co/storage/v1/s3
# For MinIO:    http://localhost:9000
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=hopeaid-uploads
S3_REGION=ap-south-1
# Optional CDN prefix
S3_PUBLIC_BASE_URL=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Use gpt-4o-mini for development, gpt-4o for production
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.1

# ─── Google APIs ─────────────────────────────────────────────────────────────
# Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_AI_FEATURES=true
ENABLE_OCR=true
ENABLE_TRANSLATION=true

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# json = production structured logs | console = human-readable dev logs
LOG_FORMAT=console
