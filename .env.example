# ─── HopeAid Backend — Environment Variables Template ────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=HopeAid
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1

# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ────────────────────────────────────────────────────────────────
# Sync SQLAlchemy driver
# Railway + Supabase: use the session pooler URL on port 5432.
# Avoid db.<project-ref>.supabase.co unless Railway outbound IPv6 is enabled.
# Example:
# DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql+psycopg2://hopeaid:hopeaid@localhost:5432/hopeaid
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (also accepts JSON array string)
CORS_ORIGINS=http://localhost:3000,http://YOUR_LAN_IP:3000,https://your-app.vercel.app

# ─── Storage (S3-compatible) ─────────────────────────────────────────────────
# Leave S3_ENDPOINT_URL empty for AWS S3
# For Supabase: https://<project>.supabase.co/storage/v1/s3
# For MinIO:    http://localhost:9000
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET_NAME=hopeaid-uploads
S3_REGION=ap-south-1
# Optional CDN prefix
S3_PUBLIC_BASE_URL=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Use gpt-4o-mini for development, gpt-4o for production
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.1

# --- Weather Intelligence / Geocoding ----------------------------------------
ENABLE_WEATHER_INTELLIGENCE=true
GEOCODING_PROVIDER=open_meteo
GEOCODING_COUNTRY_CODE=IN
GEOCODING_LANGUAGE=en
GEOCODING_TIMEOUT_SECONDS=15
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
WEATHER_MONITOR_FORECAST_HOURS=12
WEATHER_MONITOR_CASE_SCAN_LIMIT=200
WEATHER_MONITOR_CLEAR_INTERVAL_MINUTES=180
WEATHER_MONITOR_WATCH_INTERVAL_MINUTES=60
WEATHER_MONITOR_ELEVATED_INTERVAL_MINUTES=30
WEATHER_MONITOR_SEVERE_INTERVAL_MINUTES=30

# --- Optional production provider slots --------------------------------------
# Mappls / MapmyIndia
MAPPLS_API_KEY=
MAPPLS_CLIENT_ID=
MAPPLS_CLIENT_SECRET=
MAPPLS_BASE_URL=https://atlas.mappls.com

# IMD official warning feed
WEATHER_WARNING_PROVIDER=none
# Paste the confirmed district-warning URL template here later.
# Example shape: https://your-imd-endpoint.example/{state}/{district}
IMD_WARNINGS_URL_TEMPLATE=
IMD_API_KEY=
IMD_REQUEST_TIMEOUT_SECONDS=20

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ─── Google APIs ─────────────────────────────────────────────────────────────
# Path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_AI_FEATURES=true
ENABLE_OCR=true
ENABLE_TRANSLATION=true

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10
AUTH_FAILURE_WINDOW_SECONDS=900
AUTH_LOCKOUT_SECONDS=900
AUTH_MAX_FAILED_ATTEMPTS_PER_EMAIL=5
AUTH_MAX_FAILED_ATTEMPTS_PER_IP=20

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# json = production structured logs | console = human-readable dev logs
LOG_FORMAT=console
